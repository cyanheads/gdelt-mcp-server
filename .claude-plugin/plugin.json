{
  "name": "gdelt-mcp-server",
  "version": "0.2.1",
  "description": "Search and analyze global news coverage and US TV transcripts via the GDELT Project APIs.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/gdelt-mcp-server#readme",
  "repository": "https://github.com/cyanheads/gdelt-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "gdelt-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/gdelt-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
